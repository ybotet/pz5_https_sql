version: "3.8"

services:
  auth:
    build:
      context: ../..
      dockerfile: services/auth/Dockerfile
    container_name: pz5-auth
    networks:
      - pz5-network
    healthcheck:
      test: ["CMD", "grpc_health_probe", "-addr=localhost:50051"]
      interval: 30s
      timeout: 10s
      retries: 3

  tasks:
    build:
      context: ../..
      dockerfile: services/tasks/Dockerfile
    container_name: pz5-tasks
    environment:
      - AUTH_SERVICE_HOST=auth:50051
      - TASKS_PORT=8082
    networks:
      - pz5-network
    depends_on:
      auth:
        condition: service_healthy
    healthcheck:
      test:
        [
          "CMD",
          "wget",
          "--no-verbose",
          "--tries=1",
          "--spider",
          "http://localhost:8082/health",
        ]
      interval: 30s
      timeout: 10s
      retries: 3

  nginx:
    image: nginx:alpine
    container_name: pz5-nginx
    ports:
      - "8443:8443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./cert.pem:/etc/nginx/tls/cert.pem:ro
      - ./key.pem:/etc/nginx/tls/key.pem:ro
    networks:
      - pz5-network
    depends_on:
      tasks:
        condition: service_healthy
      auth:
        condition: service_healthy

networks:
  pz5-network:
    driver: bridge
